{
  "name": "business-partner-agent",
  "version": "1.0.0",
  "description": "기억을 축적하고 조언하는 비즈니스 파트너형 에이전트 - Microsoft 365 Agents SDK",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc --build",
    "start": "node --env-file .env ./dist/index.js",
    "start:anon": "node ./dist/index.js",
    "dev": "tsc --build && node --env-file .env ./dist/index.js",
    "test-tool": "agentsplayground",
    "test": "npm-run-all -p -r start:anon test-tool"
  },
  "dependencies": {
    "@microsoft/agents-hosting": "^1.4.1",
    "@microsoft/agents-hosting-express": "^1.4.1",
    "@microsoft/agents-activity": "^1.4.1",
    "@azure/openai": "^2.1.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@microsoft/m365agentsplayground": "^0.2.16",
    "@types/node": "^22.15.18",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.8.3",
    "npm-run-all": "^4.1.5"
  }
}
